# Chatbot for Your Data - Environment Configuration
# Copy this file to .env and fill in your values

# Groq API (get your free API key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Model parameters
MAX_NEW_TOKENS=256
TEMPERATURE=0.1

# Document processing
CHUNK_SIZE=1024
CHUNK_OVERLAP=64
RETRIEVAL_K=3

# Embeddings model
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2